# ─── ElfastsasaWEB3 Dashboard — Environment Variables ────────────
# Copy this file to .env.local and fill in your values.

# (Optional) Alchemy API key — used for reading on-chain data
# without relying solely on MetaMask's injected provider.
# Get one free at: https://alchemy.com
NEXT_PUBLIC_ALCHEMY_KEY=your_alchemy_api_key_here

# (Optional) Default chain ID to show on first load
# 1 = Ethereum Mainnet, 11155111 = Sepolia testnet
NEXT_PUBLIC_DEFAULT_CHAIN_ID=1

# (Optional) App URL — used for metadata / OG tags
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
